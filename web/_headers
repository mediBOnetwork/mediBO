# Cloudflare Pages response headers
# Rule evaluation: most specific match wins.

# --- Entry point: never cache ---
# index.html must always be fresh so the browser picks up new asset hashes
# and the service worker version.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# --- Flutter loader scripts: never cache ---
# These files reference the hashed JS bundles. Stale copies cause users to
# keep loading the old app even after a deploy.
/flutter.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_bootstrap.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_service_worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/main.dart.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

# --- Hashed assets: cache forever ---
# Flutter content-hashes every file under /assets/ and /canvaskit/.
# Safe to cache for 1 year; new deploys get new hashes automatically.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable
